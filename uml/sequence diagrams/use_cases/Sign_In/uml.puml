@startuml
title Sign In

actor "User" as User
participant "Controller/Input Manager" as Input
participant "HUD" as HUD
participant "Authentication UI" as AuthUI
participant "Authentication Manager" as AuthMgr
participant "Supabase Client" as Supa
participant "Game Manager" as GameMgr


alt Already authenticated
    AuthMgr --> AuthUI : User logged in
    AuthUI --> User : Hide auth UI

else Not authenticated
    AuthUI --> User : Show login panel

    User ->> AuthUI : Enter email + password
    AuthUI ->> AuthUI : Validate input

    alt Validation fails
        AuthUI --> User : Log error message

    else Validation passes
        AuthUI ->> AuthMgr : Login

        AuthMgr ->> Supa : Sign in
        Supa --> AuthMgr : Session + User

        alt Sign in failed
            AuthMgr --> AuthUI : Error
            AuthUI --> User : Log error message

        else Sign in succeeded
            AuthMgr --> AuthUI : Logged in
            AuthMgr --> GameMgr : Logged in event
            GameMgr ->> GameMgr : Update auth state
            AuthUI --> User : Hide auth UI
            GameMgr ->> User : Load gallery
        end
    end
end

@enduml





