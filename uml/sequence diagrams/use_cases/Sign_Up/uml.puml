@startuml
title Sign Up

actor "User" as User
participant "Controller/Input Manager" as Input
participant "HUD" as HUD
participant "Authentication UI" as AuthUI
participant "Authentication Manager" as AuthMgr
participant "Supabase Client" as Supa
participant "Artist Repository" as ArtistRepo


alt Already authenticated
    AuthMgr --> AuthUI : User logged in
    AuthUI --> User : Hide auth UI

else Not authenticated
    AuthUI --> User : Show login panel

    User ->> AuthUI : Clicks "Register"
    AuthUI --> User : Show register panel

    User ->> AuthUI : Enter email, password, username
    AuthUI ->> AuthUI : Validate input

    alt Validation fails
        AuthUI --> User : Log error message

    else Validation passes
        AuthUI ->> AuthMgr : Register

        AuthMgr ->> Supa : Sign up
        Supa --> AuthMgr : Session + User

        alt Sign up failed
            AuthMgr --> AuthUI : Error
            AuthUI --> User : Log serror message
            AuthUI --> User : Show register panel

        else Sign up succeeded
            AuthMgr ->> ArtistRepo : Create artist profile
            ArtistRepo ->> Supa : Insert into artists table

            alt Profile creation failed
                ArtistRepo --> AuthMgr : false
                AuthMgr --> AuthUI : Success (profile warning logged)
            else Profile created
                ArtistRepo --> AuthMgr : true
                AuthMgr --> AuthUI : Success
            end

            AuthUI --> User : Show login panel
        end
    end
end

@enduml


