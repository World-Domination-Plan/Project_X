@startuml
title Sign Up

actor User as User
participant "Controller/Input Manager" as Input
participant "HUD" as HUD
participant "AuthenticationUI" as AuthUI
participant "AuthenticationManager" as AuthMgr
participant "SupabaseClient\n(via SupabaseClientManager)" as Supa
participant "SupabaseArtistRepository" as ArtistRepo
participant "Room Manager" as Room
participant "Event Logger" as Log

User -> Input : Opens HUD
Input -> HUD : Show HUD
HUD -> AuthUI : Show login panel\n(if not authenticated)
AuthUI -> User : Display Login/Register UI

User -> AuthUI : Clicks "Show Register"
AuthUI -> User : Display Register panel\n(email, password, confirm,\nusername fields)

User -> AuthUI : Enters credentials\n+ username, clicks Register
AuthUI -> AuthUI : ValidateRegisterInput()\n[email format, password ≥6,\npasswords match]

alt Validation fails
    AuthUI -> User : Show inline error message
else Validation passes
    AuthUI -> AuthUI : ShowLoadingPanel()
    AuthUI -> AuthMgr : RegisterUser(email, password, username)
    Log -> Log : Log registration attempt

    AuthMgr -> Supa : Auth.SignUp(email, password)
    Supa --> AuthMgr : Session + User (or null)

    alt SignUp failed (no user returned)
        AuthMgr -> AuthMgr : OnAuthenticationError?.Invoke("Registration failed")
        AuthUI -> AuthUI : HandleAuthenticationError()
        AuthUI -> User : Show error message
    else SignUp succeeded
        AuthMgr -> ArtistRepo : CreateArtistProfileAsync(userId, username)
        ArtistRepo -> Supa : INSERT into artists table

        alt Profile creation failed
            ArtistRepo --> AuthMgr : false
            AuthMgr --> AuthUI : success = true\n(user created, profile warning logged)
            AuthUI -> User : "Registration successful!\nCheck email for verification."
            AuthUI -> AuthUI : ShowLoginPanel()
        else Profile created successfully
            ArtistRepo --> AuthMgr : true
            AuthMgr --> AuthUI : success = true
            Log -> Log : Log user + profile created
            AuthUI -> User : "Registration successful!\nCheck email for verification."
            AuthUI -> AuthUI : ShowLoginPanel()
        end
    end
end
@enduml
